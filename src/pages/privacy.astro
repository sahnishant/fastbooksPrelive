---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Privacy Policy | Fastbooks";
const description = "Privacy policy for Fastbooks prelaunch early access.";
---

<BaseLayout title={title} description={description} source="Privacy Policy">
  <section class="section page-hero">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p class="page-subtitle">This prelaunch site currently uses WhatsApp-based early access collection. Replace this placeholder with your final legal policy before public launch.</p>
  </section>
  <section class="section-soft"><div class="inner"><div class="card"><h2>Current early-access data</h2><p>Visitors may share name, company, mobile number, email ID and context to request early access. The form opens WhatsApp directly and does not store submissions on this static site.</p></div></div></section>
</BaseLayout>
