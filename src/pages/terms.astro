---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Terms of Use | Fastbooks";
const description = "Terms of use for the Fastbooks prelaunch website.";
---

<BaseLayout title={title} description={description} source="Terms of Use">
  <section class="section page-hero">
    <p class="eyebrow">Terms</p>
    <h1>Terms of Use</h1>
    <p class="page-subtitle">Last updated: June 3, 2026</p>
  </section>
  <section class="section-soft">
    <div class="inner">
      <div class="card" style="display: grid; gap: 24px; max-width: 800px; margin: 0 auto;">
        <h2>1. Acceptance of Terms</h2>
        <p>By accessing this prelaunch website and requesting early access to Fastbooks, you agree to comply with and be bound by these Terms of Use.</p>
        
        <h2>2. Prelaunch Services</h2>
        <p>Fastbooks is currently in a private prelaunch phase. The features, workflows, and tools showcased on this website are for demonstration and early access evaluation purposes only. Actual product capabilities, pricing, and launch dates may change without prior notice.</p>
        
        <h2>3. WhatsApp Interactions</h2>
        <p>Our primary contact point for early access requests is WhatsApp. You understand that messaging us initiates a direct communication channel. You are responsible for any mobile carrier fees or data charges associated with the use of third-party platforms like WhatsApp.</p>
        
        <h2>4. Intellectual Property</h2>
        <p>All content, text, designs, brand marks, and layout on this website are the intellectual property of Fastbooks. TallyPrime, Zoho Books, Vyapar, and other product names mentioned are trade names or registered trademarks of their respective owners and are used here for comparative context only.</p>
        
        <h2>5. Limitation of Liability</h2>
        <p>This website and the prelaunch information are provided on an "as is" basis. Fastbooks shall not be liable for any direct or indirect damages arising out of the use or inability to use this site, its tools, or its waitlist registration.</p>
        
        <h2>6. Modifications to Terms</h2>
        <p>We reserve the right to revise these Terms of Use at any time. Your continued use of the website following any changes signifies your acceptance of the updated terms.</p>
      </div>
    </div>
  </section>
</BaseLayout>
