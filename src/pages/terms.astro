---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Terms of Use | Fastbooks";
const description = "Terms of use for the Fastbooks prelaunch website.";
---

<BaseLayout title={title} description={description} source="Terms of Use">
  <section class="section page-hero">
    <p class="eyebrow">Terms</p>
    <h1>Terms of Use</h1>
    <p class="page-subtitle">This is a prelaunch website. Replace this placeholder with final legal terms before public launch.</p>
  </section>
  <section class="section-soft"><div class="inner"><div class="card"><h2>Prelaunch notice</h2><p>Fastbooks is in private early access. Product capabilities, pricing and availability may change before public release.</p></div></div></section>
</BaseLayout>
