---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page Not Found | Fastbooks";
const description = "The page you are looking for was not found. Explore Fastbooks accounting software pages for Indian businesses.";
---

<BaseLayout title={title} description={description} source="404 Page">
  <section class="section page-hero">
    <p class="eyebrow">404</p>
    <h1>Page not found.</h1>
    <p class="page-subtitle">The page may have moved, or the link may be incorrect. Explore the main Fastbooks pages below.</p>
  </section>

  <section class="section-soft">
    <div class="inner">
      <div class="card-grid two">
        <article class="card">
          <h3>Fastbooks homepage</h3>
          <p>Start with the core Fastbooks positioning: accounting without daily data entry.</p>
          <p><a href="/">Open homepage →</a></p>
        </article>
        <article class="card">
          <h3>TallyPrime alternative</h3>
          <p>See how Fastbooks reduces manual accounts entry while preserving accountant review.</p>
          <p><a href="/alternatives/tally-prime/">Open Tally alternative →</a></p>
        </article>
        <article class="card">
          <h3>Best accounting software guide</h3>
          <p>Compare common Indian accounting software categories and workflows.</p>
          <p><a href="/resources/best-accounting-software-india/">Open guide →</a></p>
        </article>
        <article class="card">
          <h3>Free GST calculator</h3>
          <p>Estimate taxable value, GST amount, CGST, SGST and invoice total.</p>
          <p><a href="/tools/free-gst-calculator/">Open GST calculator →</a></p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
