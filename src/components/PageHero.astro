---
import { buildWhatsAppUrl } from "../data/site";

const {
  eyebrow,
  title,
  subtitle,
  source,
  secondaryHref,
  secondaryLabel
} = Astro.props;
---

<section class="section page-hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="page-subtitle">{subtitle}</p>
  <div class="hero-actions">
    <a class="button button-primary" href={buildWhatsAppUrl()} target="_blank" rel="noopener noreferrer"
      data-event="request_early_access_click"
      data-page={source}
      data-cta-location="hero"
      data-source={source}
      data-target="whatsapp"
      data-analytics="hero-whatsapp-cta">
        Get Early Access on WhatsApp
      </a>
    <p class="cta-trust-note">We respect your privacy. Message opens directly in WhatsApp; no info is saved on this site.</p>
    {secondaryHref && secondaryLabel && (
      <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
    )}
  </div>
</section>
