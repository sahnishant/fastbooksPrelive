---
type ProofItem = {
  id: string;
  title: string;
  description: string;
  imageSrc: string;
  alt: string;
};

interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  items: ProofItem[];
  layout?: "grid" | "feature";
  sectionClass?: string;
}

const {
  eyebrow = "Product proof",
  title = "See how Fastbooks turns daily inputs into review-ready accounting drafts.",
  intro = "These placeholders mark the product screens we will replace with real Fastbooks screenshots as the pilot UI hardens.",
  items,
  layout = "grid",
  sectionClass = "section"
} = Astro.props;
---

<section class={sectionClass} data-analytics="section-product-proof-view">
  <div class="inner-container">
    <div class="section-heading">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      <p>{intro}</p>
    </div>

    {layout === "grid" ? (
      <div class="proof-grid">
        {items.map((item) => (
          <article class="proof-card" id={`proof-${item.id}`}>
            <div class="image-container">
              <img
                src={item.imageSrc}
                alt={item.alt}
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
                class="proof-image"
              />
              <span class="placeholder-badge">Screenshot placeholder</span>
            </div>
            <div class="proof-content">
              <h3 class="proof-item-title">{item.title}</h3>
              <p class="proof-description">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="proof-feature-stack">
        {items.map((item, index) => (
          <article class={`proof-feature-item ${index % 2 === 1 ? 'reverse' : ''}`} id={`proof-${item.id}`}>
            <div class="image-container feature-image-container">
              <img
                src={item.imageSrc}
                alt={item.alt}
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
                class="proof-image"
              />
              <span class="placeholder-badge">Screenshot placeholder</span>
            </div>
            <div class="proof-feature-content">
              <h3 class="proof-item-title">{item.title}</h3>
              <p class="proof-description">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    )}

    <div class="disclosure-note">
      <p>💡 <strong>Screenshot placeholders shown.</strong> Real Fastbooks product screens will be added as the pilot UI is hardened. <em>“AI prepares, humans/accountants approve.”</em></p>
    </div>
  </div>
</section>

<style>
  .inner-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 28px;
    margin-top: 40px;
  }

  .proof-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 18px rgba(15, 23, 42, 0.04);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .proof-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
    border-color: var(--orange);
  }

  .image-container {
    position: relative;
    background: var(--soft);
    border-bottom: 1px solid var(--border);
    aspect-ratio: 1200 / 800;
    width: 100%;
    overflow: hidden;
  }

  .proof-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #cbd5e1;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .proof-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .proof-item-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .proof-description {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Feature stack layout */
  .proof-feature-stack {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-top: 40px;
  }

  .proof-feature-item {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 18px rgba(15, 23, 42, 0.04);
  }

  .proof-feature-item.reverse {
    grid-template-columns: 0.8fr 1.2fr;
  }

  .proof-feature-item.reverse .feature-image-container {
    order: 2;
  }

  .feature-image-container {
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.02);
  }

  .proof-feature-content {
    padding: 12px;
  }

  /* Disclosure Section */
  .disclosure-note {
    margin-top: 48px;
    padding: 18px 24px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 12px;
    color: var(--navy);
    font-size: 14px;
    line-height: 1.5;
  }

  .disclosure-note p {
    margin: 0;
  }

  @media (max-width: 980px) {
    .proof-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .proof-feature-item, 
    .proof-feature-item.reverse {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .proof-feature-item.reverse .feature-image-container {
      order: 0;
    }
  }

  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
