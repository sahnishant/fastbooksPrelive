---
import { buildWhatsAppUrl } from "../data/site";

const url = buildWhatsAppUrl("Homepage");
---

<style>
.sticky-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--navy);
  padding: 12px 0;
  text-align: center;
  z-index: 1000;
  display: none;
}

@media (max-width: 980px) {
  .sticky-cta {
    display: block;
  }
  :global(body) {
    padding-bottom: 70px;
  }
}
</style>

<div class="sticky-cta">
  <a class="button button-primary" href={url} target="_blank" rel="noopener noreferrer"
     data-event="request_early_access_click"
     data-page="Homepage"
     data-cta-location="sticky"
     data-source="Homepage"
     data-target="whatsapp"
     data-analytics="sticky-whatsapp-cta">
    Get Early Access
  </a>
</div>
