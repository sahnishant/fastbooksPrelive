---
interface Props {
  eyebrow?: string;
  title?: string;
  answer: string;
  bullets?: string[];
}

const {
  eyebrow = "Direct answer",
  title = "Short answer",
  answer,
  bullets = []
} = Astro.props as Props;
---

<section class="answer-block" aria-label={title}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  <p>{answer}</p>
  {bullets.length > 0 && (
    <ul>
      {bullets.map((bullet: string) => <li>{bullet}</li>)}
    </ul>
  )}
</section>
