---
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  faqs?: FAQItem[];
}
const {
  eyebrow = "FAQ",
  title = "Frequently asked questions",
  intro = "",
  faqs = []
} = Astro.props as Props;
---

{faqs.length > 0 && (
  <section class="section-soft">
    <div class="inner">
      <div class="section-heading">
        <p class="eyebrow">{eyebrow}</p>
        <h2>{title}</h2>
        {intro && <p>{intro}</p>}
      </div>
      <div class="faq">
        {faqs.map((faq: FAQItem, index: number) => (
          <details open={index === 0}>
            <summary data-analytics="faq-toggle">{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
