---
import { footerLinks } from "../data/site";
---

<footer class="seo-footer">
  <div class="footer-grid">
    <div class="footer-column">
      <div class="footer-brand"><span class="footer-mark">F</span><strong>Fastbooks</strong></div>
      <p class="brand-desc">Accounting software for Indian businesses that prepares sales, purchase, expense and bank entries from everyday inputs for accountant review.</p>
    </div>

    <div class="footer-column">
      <h4>Capabilities</h4>
      <ul>
        {footerLinks.capabilities.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-column">
      <h4>Solutions</h4>
      <ul>
        {footerLinks.solutions.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-column">
      <h4>Resources</h4>
      <ul>
        {footerLinks.resources.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
  </div>

  <div class="footer-legal">
    <p>© 2026 Fastbooks. Public prelaunch site. TallyPrime and other product names are marks of their respective owners.</p>
    <div>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="#top">Back to top ↑</a>
    </div>
  </div>
</footer>
